{
  "name": "thungsong-launcher",
  "version": "1.2.3",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.thungsong.launcher",
    "productName": "Thungsong Launcher",
    "directories": {
      "output": "dist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    },
    "win": {
      "target": "nsis",
      "icon": "logo.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Tanapon7872",
        "repo": "TS-Launcher"
      }
    ]
  },
  "dependencies": {
    "assert-plus": "^1.0.0",
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}